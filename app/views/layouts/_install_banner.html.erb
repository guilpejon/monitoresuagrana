<div class="lg:hidden" data-controller="install-prompt" data-install-prompt-mode-value="banner">
  <div class="hidden mb-4 rounded-xl border overflow-hidden" data-install-prompt-target="banner" style="background-color: #1E2130; border-color: #6C63FF;">
    <div class="px-4 py-3 flex items-center gap-3">
      <div class="flex-shrink-0 w-8 h-8 rounded-lg flex items-center justify-center" style="background-color: rgba(108,99,255,0.2);">
        <%= svg_icon "smartphone", css_class: "w-4 h-4", stroke: "#6C63FF" %>
      </div>

      <div class="flex-1 min-w-0">
        <p class="text-sm font-semibold" style="color: #E2E8F0;"><%= t("install_prompt.banner_title") %></p>

        <p class="hidden text-xs mt-0.5 leading-relaxed" data-install-prompt-target="iosContent" style="color: #8892A4;">
          <%= t("install_prompt.banner_ios_hint") %>
        </p>

        <div class="hidden mt-1.5" data-install-prompt-target="androidContent">
          <button data-action="click->install-prompt#install"
                  class="px-3 py-1 rounded-lg text-xs font-semibold transition-colors hover:opacity-90"
                  style="background-color: #6C63FF; color: white;">
            <%= t("install_prompt.banner_android_btn") %>
          </button>
        </div>
      </div>

      <button data-action="click->install-prompt#dismiss"
              class="flex-shrink-0 p-1 rounded-lg transition-opacity opacity-50 hover:opacity-100"
              style="color: #8892A4;"
              aria-label="<%= t('install_prompt.dismiss') %>">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>
</div>
