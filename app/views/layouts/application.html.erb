<!DOCTYPE html>
<html lang="<%= I18n.locale %>" class="h-full">
  <head>
    <title><%= t("app.name") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= t("app.name") %>">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <% if user_signed_in? %>
      <meta name="user-currency" content="<%= current_user.currency || 'BRL' %>">
    <% end %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/themes/dark.css">
    <script src="<%= asset_path('chart.umd.js') %>"></script>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full" style="background-color: #0F1117; color: #E2E8F0; font-family: 'Inter', system-ui, sans-serif;">
    <% if user_signed_in? %>
      <div class="flex h-full" data-controller="sidebar">
        <%# Sidebar - desktop %>
        <%= render "layouts/sidebar" %>

        <%# Mobile overlay %>
        <div class="fixed inset-0 z-20 hidden" style="background-color: rgba(0,0,0,0.5);" data-sidebar-target="overlay" data-action="click->sidebar#close"></div>

        <%# Main content area %>
        <div class="flex flex-col flex-1 min-w-0 lg:ml-60" data-sidebar-target="content">
          <%= render "layouts/topbar" %>

          <main class="flex-1 overflow-y-auto p-4 md:p-6 pb-24 lg:pb-6">
            <% if notice %>
              <div class="mb-4 px-4 py-3 rounded-lg text-sm font-medium border flex items-center justify-between gap-4" style="background-color: rgba(0,212,170,0.1); border-color: #00D4AA; color: #00D4AA;">
                <span><%= notice %></span>
                <button type="button" onclick="this.closest('div').remove()" class="shrink-0 opacity-70 hover:opacity-100 transition-opacity cursor-pointer" aria-label="Dismiss">&times;</button>
              </div>
            <% end %>
            <% if alert %>
              <div class="mb-4 px-4 py-3 rounded-lg text-sm font-medium border flex items-center justify-between gap-4" style="background-color: rgba(255,107,107,0.1); border-color: #FF6B6B; color: #FF6B6B;">
                <span><%= alert %></span>
                <button type="button" onclick="this.closest('div').remove()" class="shrink-0 opacity-70 hover:opacity-100 transition-opacity cursor-pointer" aria-label="Dismiss">&times;</button>
              </div>
            <% end %>
            <%= yield %>
          </main>
        </div>

        <%# Mobile bottom navigation %>
        <% month_param = @current_date&.strftime('%Y-%m') %>
        <nav class="fixed bottom-0 left-0 right-0 z-30 lg:hidden flex items-center justify-around px-2 py-2 border-t" style="background-color: #1A1D27; border-color: #2A2F45;">
          <%= link_to root_path(month: month_param), class: "flex flex-col items-center gap-0.5 px-3 py-1 rounded-lg transition-colors", style: (controller_name == 'dashboard' ? 'color: #6C63FF' : 'color: #8892A4') do %>
            <%= svg_icon "home", css_class: "w-5 h-5" %>
            <span class="text-xs"><%= t("layouts.mobile_nav.home") %></span>
          <% end %>
          <%= link_to expenses_path(month: month_param), class: "flex flex-col items-center gap-0.5 px-3 py-1 rounded-lg transition-colors", style: (controller_name == 'expenses' ? 'color: #6C63FF' : 'color: #8892A4') do %>
            <%= svg_icon "credit-card", css_class: "w-5 h-5" %>
            <span class="text-xs"><%= t("layouts.mobile_nav.expenses") %></span>
          <% end %>
          <%= link_to incomes_path(month: month_param), class: "flex flex-col items-center gap-0.5 px-3 py-1 rounded-lg transition-colors", style: (controller_name == 'incomes' ? 'color: #6C63FF' : 'color: #8892A4') do %>
            <%= svg_icon "wallet", css_class: "w-5 h-5" %>
            <span class="text-xs"><%= t("layouts.mobile_nav.income") %></span>
          <% end %>
          <%= link_to investments_path(month: month_param), class: "flex flex-col items-center gap-0.5 px-3 py-1 rounded-lg transition-colors", style: (controller_name == 'investments' ? 'color: #6C63FF' : 'color: #8892A4') do %>
            <%= svg_icon "trending-up", css_class: "w-5 h-5" %>
            <span class="text-xs"><%= t("layouts.mobile_nav.invest") %></span>
          <% end %>
          <%= link_to forecast_path(month: month_param), class: "flex flex-col items-center gap-0.5 px-3 py-1 rounded-lg transition-colors", style: (controller_name == 'forecast' ? 'color: #6C63FF' : 'color: #8892A4') do %>
            <%= svg_icon "bar-chart-2", css_class: "w-5 h-5" %>
            <span class="text-xs"><%= t("layouts.mobile_nav.forecast") %></span>
          <% end %>
        </nav>

        <%# Quick Add FAB — mobile only %>
        <button class="fixed bottom-20 right-4 z-40 w-12 h-12 rounded-full flex items-center justify-center shadow-lg lg:hidden transition-transform hover:scale-110 active:scale-95"
                style="background-color: #6C63FF;"
                data-action="click->modal#open"
                data-modal-url-value="<%= new_expense_path(quick: true) %>">
          <%= svg_icon "plus", css_class: "w-6 h-6", stroke: "white" %>
        </button>
      </div>

      <%# Global modal container %>
      <div id="modal" data-controller="modal" data-modal-target="container" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4" style="background-color: rgba(0,0,0,0.7);">
        <div class="relative w-full max-w-md rounded-xl border p-6" style="background-color: #1E2130; border-color: #2A2F45;" data-modal-target="dialog">
          <div id="modal-content"></div>
        </div>
      </div>

    <% else %>
      <div class="min-h-full">
        <%= yield %>
      </div>
    <% end %>
  </body>
</html>
