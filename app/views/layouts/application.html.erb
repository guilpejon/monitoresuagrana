<!DOCTYPE html>
<html lang="<%= I18n.locale %>" class="h-full">
  <head>
    <title><%= content_for?(:title) ? "#{yield(:title)} · #{t('app.name')}" : t('app.name') %></title>
    <link rel="icon" type="image/svg+xml" href="<%= asset_path('favicon.svg') %>">
    <link rel="manifest" href="/manifest">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#6C63FF">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Grana">
    <meta name="application-name" content="<%= t("app.name") %>">

    <%# Open Graph %>
    <meta property="og:locale" content="<%= I18n.locale.to_s == 'pt-BR' ? 'pt_BR' : 'en_US' %>">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="<%= t('app.name') %>">
    <meta property="og:title" content="<%= content_for?(:title) ? "#{yield(:title)} · #{t('app.name')}" : t('app.name') %>">
    <meta property="og:description" content="<%= content_for?(:description) ? yield(:description) : t('app.description') %>">
    <meta property="og:image" content="<%= "#{request.base_url}/og-image.png" %>">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">

    <%# Twitter Card %>
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= content_for?(:title) ? "#{yield(:title)} · #{t('app.name')}" : t('app.name') %>">
    <meta name="twitter:description" content="<%= content_for?(:description) ? yield(:description) : t('app.description') %>">
    <meta name="twitter:image" content="<%= "#{request.base_url}/og-image.png" %>">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <% if user_signed_in? %>
      <meta name="user-currency" content="<%= current_user.currency || 'BRL' %>">
    <% end %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/themes/dark.css">
    <script src="<%= asset_path('chart.umd.js') %>"></script>
    <%= javascript_importmap_tags %>
    <script>if(localStorage.getItem('values-hidden')==='true'){document.documentElement.classList.add('values-hidden')}</script>
  </head>

  <body class="h-full" style="background-color: #0F1117; color: #E2E8F0; font-family: 'Inter', system-ui, sans-serif;">
    <% if user_signed_in? %>
      <div class="flex h-full" data-controller="sidebar">
        <%# Sidebar - desktop %>
        <%= render "layouts/sidebar" %>

        <%# Mobile overlay %>
        <div class="fixed inset-0 z-40 hidden" style="background-color: rgba(0,0,0,0.5);" data-sidebar-target="overlay" data-action="click->sidebar#close"></div>

        <%# Main content area %>
        <div class="flex flex-col flex-1 min-w-0 lg:ml-60" data-sidebar-target="content">
          <%= render "layouts/topbar" %>

          <main class="flex-1 overflow-y-auto p-4 md:p-6 pb-24 lg:pb-6">
            <%= render "layouts/install_banner" %>
          <% if notice %>
              <div class="mb-4 px-4 py-3 rounded-lg text-sm font-medium border flex items-center justify-between gap-4" style="background-color: rgba(0,212,170,0.1); border-color: #00D4AA; color: #00D4AA;">
                <span><%= notice %></span>
                <button type="button" onclick="this.closest('div').remove()" class="shrink-0 opacity-70 hover:opacity-100 transition-opacity cursor-pointer" aria-label="Dismiss">&times;</button>
              </div>
            <% end %>
            <% if alert %>
              <div class="mb-4 px-4 py-3 rounded-lg text-sm font-medium border flex items-center justify-between gap-4" style="background-color: rgba(255,107,107,0.1); border-color: #FF6B6B; color: #FF6B6B;">
                <span><%= alert %></span>
                <button type="button" onclick="this.closest('div').remove()" class="shrink-0 opacity-70 hover:opacity-100 transition-opacity cursor-pointer" aria-label="Dismiss">&times;</button>
              </div>
            <% end %>
            <%= yield %>
          </main>
        </div>

        <%# Mobile bottom navigation %>
        <% month_param = @current_date&.strftime('%Y-%m') %>
        <nav class="fixed bottom-0 left-0 right-0 z-30 lg:hidden flex items-center justify-around px-2 py-2 border-t" style="background-color: #1A1D27; border-color: #2A2F45;">
          <%= link_to root_path(month: month_param), class: "flex flex-col items-center gap-0.5 px-3 py-1 rounded-lg transition-colors", style: (controller_name == 'dashboard' ? 'color: #6C63FF' : 'color: #8892A4') do %>
            <%= svg_icon "home", css_class: "w-5 h-5" %>
            <span class="text-xs"><%= t("layouts.mobile_nav.home") %></span>
          <% end %>
          <%= link_to expenses_path(month: month_param), class: "flex flex-col items-center gap-0.5 px-3 py-1 rounded-lg transition-colors", style: (controller_name == 'expenses' ? 'color: #6C63FF' : 'color: #8892A4') do %>
            <%= svg_icon "credit-card", css_class: "w-5 h-5" %>
            <span class="text-xs"><%= t("layouts.mobile_nav.expenses") %></span>
          <% end %>
          <%= link_to incomes_path(month: month_param), class: "flex flex-col items-center gap-0.5 px-3 py-1 rounded-lg transition-colors", style: (controller_name == 'incomes' ? 'color: #6C63FF' : 'color: #8892A4') do %>
            <%= svg_icon "wallet", css_class: "w-5 h-5" %>
            <span class="text-xs"><%= t("layouts.mobile_nav.income") %></span>
          <% end %>
          <%= link_to investments_path(month: month_param), class: "flex flex-col items-center gap-0.5 px-3 py-1 rounded-lg transition-colors", style: (controller_name == 'investments' ? 'color: #6C63FF' : 'color: #8892A4') do %>
            <%= svg_icon "trending-up", css_class: "w-5 h-5" %>
            <span class="text-xs"><%= t("layouts.mobile_nav.invest") %></span>
          <% end %>
          <%= link_to forecast_path(month: month_param), class: "flex flex-col items-center gap-0.5 px-3 py-1 rounded-lg transition-colors", style: (controller_name == 'forecast' ? 'color: #6C63FF' : 'color: #8892A4') do %>
            <%= svg_icon "bar-chart-2", css_class: "w-5 h-5" %>
            <span class="text-xs"><%= t("layouts.mobile_nav.forecast") %></span>
          <% end %>
        </nav>

        <%# Quick Add FAB — mobile only, context-aware per section %>
        <% fab_path = {
          "expenses"      => new_expense_path,
          "incomes"       => new_income_path,
          "credit_cards"  => new_credit_card_path,
          "bank_accounts" => new_bank_account_path,
          "investments"   => new_investment_path,
          "possessions"   => new_possession_path,
          "categories"    => new_category_path,
        }.fetch(controller_name, new_expense_path) %>
        <% show_fab = !action_name.in?(%w[new edit create update]) && controller_name != "forecast" %>
        <% if show_fab %>
          <%= link_to fab_path,
                class: "fixed bottom-20 right-4 z-40 w-12 h-12 rounded-full flex items-center justify-center shadow-lg lg:hidden transition-transform hover:scale-110 active:scale-95",
                style: "background-color: #6C63FF;" do %>
            <%= svg_icon "plus", css_class: "w-6 h-6", stroke: "white" %>
          <% end %>
        <% end %>
      </div>

    <% else %>
      <div class="min-h-full">
        <% if notice %>
          <div class="fixed top-20 left-4 right-4 sm:left-1/2 sm:right-auto sm:-translate-x-1/2 sm:w-96 z-50 px-4 py-3 rounded-lg text-sm font-medium border flex items-center justify-between gap-4 shadow-lg" style="background-color: rgba(0,212,170,0.1); border-color: #00D4AA; color: #00D4AA;">
            <span><%= notice %></span>
            <button type="button" onclick="this.closest('div').remove()" class="shrink-0 opacity-70 hover:opacity-100 transition-opacity cursor-pointer" aria-label="Dismiss">&times;</button>
          </div>
        <% end %>
        <% if alert %>
          <div class="fixed top-20 left-4 right-4 sm:left-1/2 sm:right-auto sm:-translate-x-1/2 sm:w-96 z-50 px-4 py-3 rounded-lg text-sm font-medium border flex items-center justify-between gap-4 shadow-lg" style="background-color: rgba(255,107,107,0.1); border-color: #FF6B6B; color: #FF6B6B;">
            <span><%= alert %></span>
            <button type="button" onclick="this.closest('div').remove()" class="shrink-0 opacity-70 hover:opacity-100 transition-opacity cursor-pointer" aria-label="Dismiss">&times;</button>
          </div>
        <% end %>
        <%= yield %>
      </div>
    <% end %>
  </body>
</html>
