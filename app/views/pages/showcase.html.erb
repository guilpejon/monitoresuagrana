        <!-- Mar (current month — brighter) -->
        <rect x="480" y="270" width="28" height="135" rx="3" fill="#6C63FF"/>
        <rect x="512" y="340" width="22" height="65" rx="3" fill="#FF6B6B"/>
        <text x="502" y="418" fill="#E2E8F0" font-size="9" font-weight="600" font-family="system-ui, sans-serif" text-anchor="middle">Mar</text>

        <!-- Expenses panel (right) -->
        <rect x="600" y="200" width="384" height="230" rx="10" fill="#1E2130" stroke="#2A2F45" stroke-width="1"/>
        <text x="616" y="222" fill="#E2E8F0" font-size="12" font-weight="600" font-family="system-ui, sans-serif">Top Expenses</text>
        <text x="962" y="222" fill="#8892A4" font-size="10" font-family="system-ui, sans-serif" text-anchor="end">March</text>

        <!-- Expense rows -->
        <circle cx="628" cy="248" r="6" fill="#FF6B6B"/>
        <text x="642" y="252" fill="#E2E8F0" font-size="11" font-family="system-ui, sans-serif">Housing</text>
        <text x="962" y="252" fill="#E2E8F0" font-size="11" font-weight="600" font-family="system-ui, sans-serif" text-anchor="end">$1,200</text>
        <rect x="616" y="260" width="346" height="1" fill="#2A2F45"/>
        <rect x="616" y="260" width="195" height="1" fill="#FF6B6B" opacity="0.5"/>

        <circle cx="628" cy="279" r="6" fill="#F7B731"/>
        <text x="642" y="283" fill="#E2E8F0" font-size="11" font-family="system-ui, sans-serif">Food &amp; Dining</text>
        <text x="962" y="283" fill="#E2E8F0" font-size="11" font-weight="600" font-family="system-ui, sans-serif" text-anchor="end">$680</text>
        <rect x="616" y="291" width="346" height="1" fill="#2A2F45"/>
        <rect x="616" y="291" width="110" height="1" fill="#F7B731" opacity="0.5"/>

        <circle cx="628" cy="310" r="6" fill="#6C63FF"/>
        <text x="642" y="314" fill="#E2E8F0" font-size="11" font-family="system-ui, sans-serif">Transport</text>
        <text x="962" y="314" fill="#E2E8F0" font-size="11" font-weight="600" font-family="system-ui, sans-serif" text-anchor="end">$420</text>
        <rect x="616" y="322" width="346" height="1" fill="#2A2F45"/>
        <rect x="616" y="322" width="68" height="1" fill="#6C63FF" opacity="0.5"/>

        <circle cx="628" cy="341" r="6" fill="#60A5FA"/>
        <text x="642" y="345" fill="#E2E8F0" font-size="11" font-family="system-ui, sans-serif">Subscriptions</text>
        <text x="962" y="345" fill="#E2E8F0" font-size="11" font-weight="600" font-family="system-ui, sans-serif" text-anchor="end">$230</text>
        <rect x="616" y="353" width="346" height="1" fill="#2A2F45"/>
        <rect x="616" y="353" width="37" height="1" fill="#60A5FA" opacity="0.5"/>

