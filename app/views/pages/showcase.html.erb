          <rect x="24" y="40" width="8" height="8" rx="2" fill="#00D4AA"/>
          <text x="36" y="48" fill="#8892A4" font-size="9" font-family="system-ui, sans-serif">Income</text>
          <rect x="90" y="40" width="8" height="8" rx="2" fill="#FF6B6B"/>
          <text x="102" y="48" fill="#8892A4" font-size="9" font-family="system-ui, sans-serif">Expenses</text>

          <!-- Grid -->
