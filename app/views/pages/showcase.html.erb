        <text x="440" y="572" fill="#8892A4" font-size="8" font-family="system-ui, sans-serif" text-anchor="middle">May</text>
        <text x="590" y="572" fill="#8892A4" font-size="8" font-family="system-ui, sans-serif" text-anchor="middle">Jul</text>
