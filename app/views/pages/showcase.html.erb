  <%# Stats bar %>
  <section class="py-14 px-6 max-w-5xl mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      <div class="py-6 px-4 rounded-2xl border" style="background-color: #1E2130; border-color: #2A2F45;">
