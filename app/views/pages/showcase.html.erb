        <line x1="50" y1="305" x2="550" y2="305" stroke="#2A2F45" stroke-width="0.5"/>
        <line x1="50" y1="340" x2="550" y2="340" stroke="#2A2F45" stroke-width="0.5"/>
        <line x1="50" y1="375" x2="550" y2="375" stroke="#2A2F45" stroke-width="0.5"/>
        <!-- Baseline -->
