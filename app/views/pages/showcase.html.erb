              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><polyline points="2,6 5,9 10,3" stroke="#6C63FF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <span style="color: #C4CADB;"><%= t("pages.showcase.spotlight1_point2") %></span>
          </li>
