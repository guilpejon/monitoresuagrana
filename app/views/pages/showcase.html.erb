      <div class="py-6 px-4 rounded-2xl border" style="background-color: #1E2130; border-color: #2A2F45;">
        <div class="text-4xl font-bold mb-1" style="color: #00D4AA;">6</div>
        <div class="text-sm" style="color: #8892A4;"><%= t("pages.showcase.stat2_label") %></div>
      </div>
      <div class="py-6 px-4 rounded-2xl border" style="background-color: #1E2130; border-color: #2A2F45;">
        <div class="text-4xl font-bold mb-1" style="color: #F7B731;">3</div>
        <div class="text-sm" style="color: #8892A4;"><%= t("pages.showcase.stat3_label") %></div>
      </div>
      <div class="py-6 px-4 rounded-2xl border" style="background-color: #1E2130; border-color: #2A2F45;">
        <div class="text-4xl font-bold mb-1" style="color: #FF6B6B;">&#8734;</div>
        <div class="text-sm" style="color: #8892A4;"><%= t("pages.showcase.stat4_label") %></div>
      </div>
    </div>
  </section>

  <%# Divider %>
