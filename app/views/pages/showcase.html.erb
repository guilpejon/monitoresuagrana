          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#34D399" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline>
            <polyline points="17 6 23 6 23 12"></polyline>
          </svg>
        </div>
        <h3 class="font-semibold text-base mb-2 text-center" style="color: #E2E8F0;"><%= t("pages.showcase.investments_title") %></h3>
        <p class="text-sm leading-relaxed text-center" style="color: #8892A4;"><%= t("pages.showcase.investments_desc") %></p>
      </div>

      <%# Forecast %>
      <div class="rounded-2xl border p-6 transition-all hover:border-opacity-80 hover:-translate-y-1 hover:shadow-lg feature-card" style="background-color: #1E2130; border-color: #2A2F45;">
        <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 mx-auto" style="background-color: rgba(96,165,250,0.15);">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#60A5FA" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="20" x2="18" y2="10"></line>
            <line x1="12" y1="20" x2="12" y2="4"></line>
            <line x1="6" y1="20" x2="6" y2="14"></line>
          </svg>
        </div>
        <h3 class="font-semibold text-base mb-2 text-center" style="color: #E2E8F0;"><%= t("pages.showcase.forecast_title") %></h3>
        <p class="text-sm leading-relaxed text-center" style="color: #8892A4;"><%= t("pages.showcase.forecast_desc") %></p>
      </div>

    </div>
  </section>

  <%# Divider %>
  <div class="max-w-6xl mx-auto px-4">
    <hr style="border-color: #2A2F45;">
  </div>

  <%# Feature Spotlight 3 — Forecast %>
  <section class="py-10 sm:py-24 px-6 max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-center">
      <div>
        <div class="inline-block px-3 py-1 rounded-full text-xs font-semibold mb-5 border" style="background-color: rgba(96,165,250,0.1); border-color: rgba(96,165,250,0.3); color: #60A5FA;">
          <%= t("pages.showcase.spotlight3_badge") %>
        </div>
        <h2 class="text-4xl font-bold mb-5 leading-snug"><%= t("pages.showcase.spotlight3_title") %></h2>
        <p class="text-lg mb-8 leading-relaxed" style="color: #8892A4;"><%= t("pages.showcase.spotlight3_desc") %></p>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <div class="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color: rgba(96,165,250,0.12);">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><polyline points="2,6 5,9 10,3" stroke="#60A5FA" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <span style="color: #C4CADB;"><%= t("pages.showcase.spotlight3_point1") %></span>
          </li>
          <li class="flex items-start gap-3">
            <div class="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color: rgba(96,165,250,0.12);">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><polyline points="2,6 5,9 10,3" stroke="#60A5FA" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <span style="color: #C4CADB;"><%= t("pages.showcase.spotlight3_point2") %></span>
          </li>
          <li class="flex items-start gap-3">
            <div class="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color: rgba(96,165,250,0.12);">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><polyline points="2,6 5,9 10,3" stroke="#60A5FA" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <span style="color: #C4CADB;"><%= t("pages.showcase.spotlight3_point3") %></span>
          </li>
        </ul>
      </div>

      <%# Forecast chart illustration %>
      <div class="hidden sm:block rounded-2xl overflow-hidden border" style="background-color: #1E2130; border-color: #2A2F45;">
        <svg viewBox="0 0 540 300" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
          <defs>
            <linearGradient id="projectionGrad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#6C63FF" stop-opacity="0.3"/>
              <stop offset="100%" stop-color="#6C63FF" stop-opacity="0"/>
            </linearGradient>
            <linearGradient id="pastGrad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#00D4AA" stop-opacity="0.15"/>
              <stop offset="100%" stop-color="#00D4AA" stop-opacity="0"/>
            </linearGradient>
          </defs>

          <!-- Header -->
          <text x="24" y="28" fill="#E2E8F0" font-size="13" font-weight="600" font-family="system-ui, sans-serif">Balance Forecast</text>
          <rect x="390" y="15" width="126" height="20" rx="4" fill="rgba(96,165,250,0.1)" stroke="rgba(96,165,250,0.2)" stroke-width="1"/>
          <text x="453" y="28" fill="#60A5FA" font-size="9" font-family="system-ui, sans-serif" text-anchor="middle">Jan → Dec 2026</text>

          <!-- Grid -->
          <line x1="50" y1="48"  x2="516" y2="48"  stroke="#2A2F45" stroke-width="0.5"/>
          <line x1="50" y1="88"  x2="516" y2="88"  stroke="#2A2F45" stroke-width="0.5"/>
          <line x1="50" y1="128" x2="516" y2="128" stroke="#2A2F45" stroke-width="0.5"/>
          <line x1="50" y1="168" x2="516" y2="168" stroke="#2A2F45" stroke-width="0.5"/>
          <line x1="50" y1="208" x2="516" y2="208" stroke="#2A2F45" stroke-width="0.5"/>
          <line x1="50" y1="242" x2="516" y2="242" stroke="#2A2F45" stroke-width="1"/>

          <!-- Y-axis labels -->
          <text x="44" y="52"  fill="#8892A4" font-size="8" font-family="system-ui, sans-serif" text-anchor="end">$12k</text>
          <text x="44" y="92"  fill="#8892A4" font-size="8" font-family="system-ui, sans-serif" text-anchor="end">$9k</text>
          <text x="44" y="132" fill="#8892A4" font-size="8" font-family="system-ui, sans-serif" text-anchor="end">$6k</text>
          <text x="44" y="172" fill="#8892A4" font-size="8" font-family="system-ui, sans-serif" text-anchor="end">$3k</text>
          <text x="44" y="212" fill="#8892A4" font-size="8" font-family="system-ui, sans-serif" text-anchor="end">$0</text>

          <!--
            9 months: Jan(x=50), Feb(x=108), Mar(x=166), Apr(x=224), May(x=282), Jun(x=340), Jul(x=398), Aug(x=456), Sep(x=514)
            Balance: $4,000→$4,280→$4,500 (solid past), then projection to $8,200 by Sep
            y = 242 - (val/14000)*194
            Jan $4000 → 242 - 55.4 = 187
            Feb $4280 → 242 - 59.3 = 183
            Mar $4500 → 242 - 62.4 = 180  ← today
            Apr $5100 → 242 - 70.7 = 171
            May $5800 → 242 - 80.4 = 162
            Jun $6600 → 242 - 91.5 = 151
            Jul $7200 → 242 - 99.8 = 142
            Aug $7750 → 242 - 107.4 = 135
            Sep $8200 → 242 - 113.6 = 128
          -->

          <!-- Past area fill -->
          <path d="M 50,187 C 79,185 93,183 108,183 C 137,183 151,180 166,180 L 166,242 L 50,242 Z" fill="url(#pastGrad)"/>

          <!-- Past solid line -->
          <path d="M 50,187 C 79,185 93,183 108,183 C 137,183 151,180 166,180" fill="none" stroke="#00D4AA" stroke-width="2.5" stroke-linecap="round"/>

          <!-- Today vertical marker -->
          <line x1="166" y1="48" x2="166" y2="242" stroke="#6C63FF" stroke-width="1" stroke-dasharray="4,3" opacity="0.5"/>
          <rect x="138" y="48" width="56" height="16" rx="4" fill="#6C63FF" opacity="0.15"/>
          <text x="166" y="59" fill="#A78BFA" font-size="8" font-family="system-ui, sans-serif" text-anchor="middle">Today · Mar</text>

          <!-- Projection area fill -->
          <path d="M 166,180 C 195,176 209,171 224,171 C 253,171 267,162 282,162 C 311,162 325,151 340,151 C 369,151 383,142 398,142 C 427,142 441,135 456,135 C 485,135 499,128 514,128 L 514,242 L 166,242 Z" fill="url(#projectionGrad)"/>

          <!-- Projection dashed line -->
          <path d="M 166,180 C 195,176 209,171 224,171 C 253,171 267,162 282,162 C 311,162 325,151 340,151 C 369,151 383,142 398,142 C 427,142 441,135 456,135 C 485,135 499,128 514,128" fill="none" stroke="#6C63FF" stroke-width="2.5" stroke-dasharray="6,4" stroke-linecap="round"/>

          <!-- Data points: past -->
          <circle cx="50"  cy="187" r="4" fill="#00D4AA"/>
          <circle cx="108" cy="183" r="4" fill="#00D4AA"/>
          <circle cx="166" cy="180" r="5" fill="#6C63FF" stroke="#1E2130" stroke-width="2"/>

          <!-- Data points: projection -->
          <circle cx="224" cy="171" r="3.5" fill="#6C63FF" opacity="0.7"/>
          <circle cx="282" cy="162" r="3.5" fill="#6C63FF" opacity="0.7"/>
          <circle cx="340" cy="151" r="3.5" fill="#6C63FF" opacity="0.7"/>
          <circle cx="398" cy="142" r="3.5" fill="#6C63FF" opacity="0.7"/>
          <circle cx="456" cy="135" r="3.5" fill="#6C63FF" opacity="0.7"/>
          <circle cx="514" cy="128" r="3.5" fill="#6C63FF" opacity="0.7"/>

          <!-- Sep annotation bubble -->
          <rect x="430" y="100" width="90" height="32" rx="6" fill="#252A3D" stroke="#2A2F45" stroke-width="1"/>
          <text x="475" y="115" fill="#8892A4" font-size="8" font-family="system-ui, sans-serif" text-anchor="middle">Sep projection</text>
          <text x="475" y="127" fill="#6C63FF" font-size="11" font-weight="bold" font-family="system-ui, sans-serif" text-anchor="middle">+$3,720</text>
          <line x1="514" y1="128" x2="514" y2="132" stroke="#6C63FF" stroke-width="1" opacity="0.5"/>

          <!-- X-axis labels -->
          <text x="50"  y="256" fill="#8892A4" font-size="9" font-family="system-ui, sans-serif" text-anchor="middle">Jan</text>
          <text x="108" y="256" fill="#8892A4" font-size="9" font-family="system-ui, sans-serif" text-anchor="middle">Feb</text>
          <text x="166" y="256" fill="#E2E8F0" font-size="9" font-weight="600" font-family="system-ui, sans-serif" text-anchor="middle">Mar</text>
          <text x="224" y="256" fill="#8892A4" font-size="9" font-family="system-ui, sans-serif" text-anchor="middle">Apr</text>
          <text x="282" y="256" fill="#8892A4" font-size="9" font-family="system-ui, sans-serif" text-anchor="middle">May</text>
          <text x="340" y="256" fill="#8892A4" font-size="9" font-family="system-ui, sans-serif" text-anchor="middle">Jun</text>
          <text x="398" y="256" fill="#8892A4" font-size="9" font-family="system-ui, sans-serif" text-anchor="middle">Jul</text>
          <text x="456" y="256" fill="#8892A4" font-size="9" font-family="system-ui, sans-serif" text-anchor="middle">Aug</text>
          <text x="514" y="256" fill="#8892A4" font-size="9" font-family="system-ui, sans-serif" text-anchor="middle">Sep</text>

          <!-- Legend -->
          <line x1="24" y1="276" x2="44" y2="276" stroke="#00D4AA" stroke-width="2"/>
          <text x="48" y="280" fill="#8892A4" font-size="9" font-family="system-ui, sans-serif">Actual</text>
          <line x1="100" y1="276" x2="120" y2="276" stroke="#6C63FF" stroke-width="2" stroke-dasharray="5,3"/>
          <text x="124" y="280" fill="#8892A4" font-size="9" font-family="system-ui, sans-serif">Projected</text>
        </svg>
      </div>
    </div>
  </section>

  <%# Divider %>
  <div class="max-w-6xl mx-auto px-4">
    <hr style="border-color: #2A2F45;">
  </div>

  <%# Final CTA %>
  <section class="py-20 px-6">
    <div class="max-w-2xl mx-auto rounded-2xl border p-12 text-center" style="background-color: #1E2130; border-color: #2A2F45;">
      <div class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto mb-6" style="background-color: rgba(108,99,255,0.15);">
        <%= svg_icon "wallet", css_class: "w-7 h-7", stroke: "#6C63FF" %>
      </div>
      <h2 class="text-3xl font-bold mb-3"><%= t("pages.showcase.cta_title") %></h2>
      <p class="mb-6 text-base" style="color: #8892A4;"><%= t("pages.showcase.cta_description") %></p>
      <div class="flex flex-wrap items-center justify-center gap-4 mb-8 text-sm" style="color: #8892A4;">
        <span>&#10003; <%= t("pages.showcase.cta_benefit1") %></span>
        <span>&#10003; <%= t("pages.showcase.cta_benefit2") %></span>
      </div>
      <%= link_to t("pages.showcase.cta_button"), new_user_registration_path,
            class: "inline-block px-10 py-3 rounded-xl font-semibold text-white transition-opacity hover:opacity-90",
            style: "background-color: #6C63FF;" %>
      <p class="mt-5 text-sm" style="color: #8892A4;">
        <%= t("pages.showcase.cta_signin_prefix") %>
        <%= link_to t("pages.showcase.cta_signin"), new_user_session_path,
              class: "font-medium hover:opacity-80",
              style: "color: #6C63FF;" %>
      </p>
    </div>
  </section>

  <%# Footer %>
  <footer class="border-t px-6 py-6" style="border-color: #2A2F45;">
    <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-sm" style="color: #8892A4;">
        &copy; <%= Date.current.year %> <%= t("app.name") %>
      </p>
      <div class="flex items-center gap-1">
        <%= link_to "PT", set_locale_path(locale: "pt-BR"),
              class: "px-3 py-1.5 rounded-md text-xs font-semibold transition-opacity",
              style: I18n.locale.to_s == "pt-BR" ? "background-color: #2A2F45; color: #E2E8F0;" : "color: #8892A4;" %>
        <%= link_to "EN", set_locale_path(locale: "en"),
              class: "px-3 py-1.5 rounded-md text-xs font-semibold transition-opacity",
              style: I18n.locale.to_s == "en" ? "background-color: #2A2F45; color: #E2E8F0;" : "color: #8892A4;" %>
        <%= link_to "ES", set_locale_path(locale: "es"),
              class: "px-3 py-1.5 rounded-md text-xs font-semibold transition-opacity",
              style: I18n.locale.to_s == "es" ? "background-color: #2A2F45; color: #E2E8F0;" : "color: #8892A4;" %>
      </div>
    </div>
  </footer>

</div>
