        <text x="30" y="464" fill="#8892A4" font-size="10" font-family="system-ui, sans-serif">6-MONTH FORECAST</text>

        <!-- Forecast line with gradient area -->
        <path d="M 140,530 C 200,526 230,523 290,520 C 350,517 380,514 440,511 C 500,507 530,505 590,504 C 650,500 680,498 740,497 C 800,495 840,493 900,492 L 900,558 L 140,558 Z" fill="url(#forecastGrad)"/>
        <path d="M 140,530 C 200,526 230,523 290,520 C 350,517 380,514 440,511 C 500,507 530,505 590,504 C 650,500 680,498 740,497 C 800,495 840,493 900,492" fill="none" stroke="#6C63FF" stroke-width="2" stroke-dasharray="5,3"/>

