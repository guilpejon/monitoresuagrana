<% provide :title, t('.title') %>
<div class="space-y-6">

  <%# Summary Cards %>
  <div class="grid grid-cols-2 lg:grid-cols-5 gap-4">
    <%# Net Balance %>
    <div class="rounded-xl border p-4" style="background-color: #1E2130; border-color: #2A2F45;">
      <div class="flex items-center justify-between mb-3">
        <span class="text-xs font-medium uppercase tracking-wide" style="color: #8892A4;"><%= t("dashboard.net_balance") %></span>
        <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background-color: rgba(108,99,255,0.15);">
          <%= svg_icon "bar-chart-2", css_class: "w-4 h-4", stroke: "#6C63FF" %>
        </div>
      </div>
      <p class="text-xl font-bold" style="color: <%= @net_balance >= 0 ? '#00D4AA' : '#FF6B6B' %>;"><%= format_currency(@net_balance) %></p>
      <p class="text-xs mt-1" style="color: #8892A4;"><%= link_to t("dashboard.see_full_projection"), forecast_path, class: "hover:opacity-80 transition-opacity", style: "color: #6C63FF;" %></p>
    </div>

    <%# Bank Accounts %>
    <div class="rounded-xl border p-4" style="background-color: #1E2130; border-color: #2A2F45;">
      <div class="flex items-center justify-between mb-3">
        <span class="text-xs font-medium uppercase tracking-wide" style="color: #8892A4;"><%= t("dashboard.bank_balance") %></span>
        <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background-color: rgba(108,99,255,0.15);">
          <%= svg_icon "landmark", css_class: "w-4 h-4", stroke: "#6C63FF" %>
        </div>
      </div>
      <p class="text-xl font-bold" style="color: #6C63FF;"><%= format_currency(@total_bank_balance) %></p>
      <p class="text-xs mt-1" style="color: #8892A4;"><%= link_to t("dashboard.view_accounts"), bank_accounts_path, class: "hover:opacity-80 transition-opacity", style: "color: #6C63FF;" %></p>
    </div>

    <%# Credit Card Bills %>
    <div class="rounded-xl border p-4" style="background-color: #1E2130; border-color: #2A2F45;">
      <div class="flex items-center justify-between mb-3">
        <span class="text-xs font-medium uppercase tracking-wide" style="color: #8892A4;"><%= t("dashboard.card_bills") %></span>
        <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background-color: rgba(247,183,49,0.15);">
          <%= svg_icon "credit-card", css_class: "w-4 h-4", stroke: "#F7B731" %>
        </div>
      </div>
      <p class="text-xl font-bold" style="color: #F7B731;"><%= format_currency(@total_card_bills) %></p>
      <p class="text-xs mt-1" style="color: #8892A4;"><%= link_to t("dashboard.card_count", count: @credit_cards.count), credit_cards_path, class: "hover:opacity-80 transition-opacity", style: "color: #F7B731;" %></p>
    </div>

    <%# Investments %>
    <div class="rounded-xl border p-4" style="background-color: #1E2130; border-color: #2A2F45;">
      <div class="flex items-center justify-between mb-3">
        <span class="text-xs font-medium uppercase tracking-wide" style="color: #8892A4;"><%= t("dashboard.investments") %></span>
        <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background-color: rgba(0,212,170,0.15);">
          <%= svg_icon "trending-up", css_class: "w-4 h-4", stroke: "#00D4AA" %>
        </div>
      </div>
      <p class="text-xl font-bold" style="color: #00D4AA;"><%= format_currency(@total_portfolio_value) %></p>
      <% profit_color = @portfolio_profit_loss >= 0 ? "#00D4AA" : "#FF6B6B" %>
      <%= link_to investments_path, class: "text-xs mt-1 block hover:opacity-80 transition-opacity", style: "color: #{profit_color};" do %>
        <%= @portfolio_profit_loss >= 0 ? "+" : "" %><%= format_currency(@portfolio_profit_loss) %> (<%= @portfolio_profit_loss >= 0 ? "+" : "" %><%= @portfolio_profit_loss_percent %>%)
      <% end %>
    </div>

    <%# Possessions %>
    <div class="col-span-2 lg:col-span-1 rounded-xl border p-4" style="background-color: #1E2130; border-color: #2A2F45;">
      <div class="flex items-center justify-between mb-3">
        <span class="text-xs font-medium uppercase tracking-wide" style="color: #8892A4;"><%= t("dashboard.possessions") %></span>
        <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background-color: rgba(167,139,250,0.15);">
          <%= svg_icon "layers", css_class: "w-4 h-4", stroke: "#A78BFA" %>
        </div>
      </div>
      <p class="text-xl font-bold" style="color: #A78BFA;"><%= format_currency(@total_possessions_value) %></p>
      <p class="text-xs mt-1" style="color: #8892A4;"><%= link_to t("dashboard.view_possessions"), possessions_path, class: "hover:opacity-80 transition-opacity", style: "color: #A78BFA;" %></p>
    </div>
  </div>

  <%# Charts Row %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <%# Wealth Distribution – Donut %>
    <div class="rounded-xl border p-5" style="background-color: #1E2130; border-color: #2A2F45;">
      <h2 class="text-sm font-semibold mb-4" style="color: #E2E8F0;"><%= t("dashboard.wealth_distribution") %></h2>
      <% if @wealth_distribution.any? %>
        <%= pie_chart @wealth_distribution.transform_keys { |k| t("dashboard.wealth.#{k}") },
            donut: true,
            colors: ["#6C63FF", "#00D4AA", "#A78BFA"],
            legend: true,
            library: {
              plugins: {
                legend: {
                  position: "bottom",
                  labels: { color: "#8892A4", font: { size: 12 }, padding: 12 }
                }
              }
            } %>
      <% else %>
        <%= render "shared/empty_state", message: t("dashboard.no_wealth_data") %>
      <% end %>
    </div>

    <%# Portfolio Allocation – Donut %>
    <div class="rounded-xl border p-5" style="background-color: #1E2130; border-color: #2A2F45;">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-sm font-semibold" style="color: #E2E8F0;"><%= t("dashboard.portfolio_allocation") %></h2>
        <%= link_to t("dashboard.view_investments"), investments_path, class: "text-xs font-medium hover:opacity-80 transition-opacity", style: "color: #00D4AA;" %>
      </div>
      <% if @portfolio_by_type.any? %>
        <%= pie_chart @portfolio_by_type.transform_keys { |type| t("dashboard.investment_type.#{type}") },
            donut: true,
            colors: ["#00D4AA", "#6C63FF", "#F7B731"],
            legend: true,
            library: {
              plugins: {
                legend: {
                  position: "bottom",
                  labels: { color: "#8892A4", font: { size: 12 }, padding: 12 }
                }
              }
            } %>
      <% else %>
        <%= render "shared/empty_state", message: t("dashboard.no_investments") %>
      <% end %>
    </div>

    <%# Monthly Cash Flow – Bar %>
    <div class="rounded-xl border p-5" style="background-color: #1E2130; border-color: #2A2F45;" data-currency-axis="x">
      <h2 class="text-sm font-semibold mb-4" style="color: #E2E8F0;"><%= t("dashboard.cash_flow") %></h2>
      <% if @monthly_income.any? || @monthly_expenses.any? %>
        <%= bar_chart [
              { name: t("dashboard.income_label"), data: @monthly_income },
              { name: t("dashboard.expenses_label"), data: @monthly_expenses }
            ],
            colors: ["#00D4AA", "#FF6B6B"],
            library: {
              plugins: {
                legend: {
                  labels: { color: "#8892A4", font: { size: 12 } }
                }
              },
              scales: {
                x: { ticks: { color: "#8892A4" }, grid: { color: "#2A2F45" } },
                y: { ticks: { color: "#8892A4" }, grid: { color: "#2A2F45" } }
              }
            } %>
      <% else %>
        <%= render "shared/empty_state", message: t("dashboard.no_data_6_months") %>
      <% end %>
    </div>
  </div>

  <%# Spending by Category Row %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <%# Spending by Category – Last 6 Months (donut) %>
    <div class="rounded-xl border p-5" style="background-color: #1E2130; border-color: #2A2F45;">
      <h2 class="text-sm font-semibold mb-4" style="color: #E2E8F0;"><%= t("dashboard.spending_by_category_6m") %></h2>
      <% if @expenses_by_category_6m.any? %>
        <%= pie_chart @expenses_by_category_6m.transform_keys { |k| t("category_names.#{k}", default: k) },
            donut: true,
            colors: @expenses_by_category_6m_colors,
            legend: true,
            library: {
              plugins: {
                legend: {
                  position: "bottom",
                  labels: { color: "#8892A4", font: { size: 12 }, padding: 12 }
                }
              }
            } %>
      <% else %>
        <%= render "shared/empty_state", message: t("dashboard.no_data_6_months") %>
      <% end %>
    </div>

    <%# Spending by Category – Last 12 Months (stacked bar) %>
    <div class="rounded-xl border p-5" style="background-color: #1E2130; border-color: #2A2F45;" data-currency-axis="x">
      <h2 class="text-sm font-semibold mb-4" style="color: #E2E8F0;"><%= t("dashboard.spending_by_category_12m") %></h2>
      <% if @expenses_by_category_12m.any? %>
        <%= bar_chart @expenses_by_category_12m.map { |h| { name: t("category_names.#{h[:name]}", default: h[:name]), data: h[:data] } },
            stacked: true,
            colors: @expenses_by_category_12m_colors,
            library: {
              plugins: {
                legend: {
                  position: "bottom",
                  labels: { color: "#8892A4", font: { size: 12 }, padding: 12 }
                }
              },
              scales: {
                x: { ticks: { color: "#8892A4" }, grid: { color: "#2A2F45" } },
                y: { ticks: { color: "#8892A4" }, grid: { color: "#2A2F45" } }
              }
            } %>
      <% else %>
        <%= render "shared/empty_state", message: t("dashboard.no_data_12_months") %>
      <% end %>
    </div>
  </div>

  <%# Recent Transactions %>
  <div class="rounded-xl border p-5" style="background-color: #1E2130; border-color: #2A2F45;">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-sm font-semibold" style="color: #E2E8F0;"><%= t("dashboard.recent_transactions") %></h2>
      <%= link_to t("dashboard.view_all"), expenses_path, class: "text-xs font-medium hover:opacity-80 transition-opacity", style: "color: #6C63FF;" %>
    </div>

    <% if @recent_transactions.any? %>
      <div class="space-y-3">
        <% @recent_transactions.each do |expense| %>
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background-color: <%= expense.category.color %>22;">
              <%= svg_icon expense.category.icon, css_class: "w-4 h-4", stroke: expense.category.color %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium truncate" style="color: #E2E8F0;"><%= expense.description %></p>
              <p class="text-xs" style="color: #8892A4;"><%= category_display_name(expense.category) %> · <%= expense.date.strftime("%d %b") %></p>
            </div>
            <span class="text-sm font-semibold flex-shrink-0" style="color: #FF6B6B;"><%= format_currency(expense.amount) %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <%= render "shared/empty_state", message: t("dashboard.no_recent_transactions") %>
    <% end %>
  </div>

</div>
