<div class="min-h-screen flex items-center justify-center px-4" style="background-color: #0F1117;">
  <div class="w-full max-w-sm">
    <div class="flex flex-col items-center mb-8">
      <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-3" style="background-color: #6C63FF;">
        <%= svg_icon "wallet", css_class: "w-6 h-6", stroke: "white" %>
      </div>
      <h1 class="text-2xl font-bold" style="color: #E2E8F0;"><%= t("app.name") %></h1>
      <p class="text-sm mt-1" style="color: #8892A4;"><%= t("devise.registrations.new.create_account") %></p>
    </div>

    <div class="rounded-xl border p-6" style="background-color: #1E2130; border-color: #2A2F45;">
      <h2 class="text-base font-semibold mb-5" style="color: #E2E8F0;"><%= t("devise.registrations.new.sign_up") %></h2>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :name, class: "block text-xs font-medium mb-1.5", style: "color: #8892A4;" %>
          <%= f.text_field :name, autofocus: true, autocomplete: "name",
              class: "w-full px-3 py-2.5 rounded-lg border text-sm outline-none transition-all",
              style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;",
              placeholder: t("devise.registrations.new.name_placeholder") %>
        </div>

        <div>
          <%= f.label :email, class: "block text-xs font-medium mb-1.5", style: "color: #8892A4;" %>
          <%= f.email_field :email, autocomplete: "email",
              class: "w-full px-3 py-2.5 rounded-lg border text-sm outline-none transition-all",
              style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;",
              placeholder: "you@example.com" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-xs font-medium mb-1.5", style: "color: #8892A4;" do %>
            <%= t("devise.registrations.new.password_label") %> <% if @minimum_password_length %><span class="font-normal">(<%= @minimum_password_length %><%= t("devise.registrations.new.password_hint") %>)</span><% end %>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password",
              class: "w-full px-3 py-2.5 rounded-lg border text-sm outline-none transition-all",
              style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;",
              placeholder: "••••••••" %>
        </div>

        <div>
          <%= f.label :password_confirmation, t("devise.registrations.new.confirm_password"), class: "block text-xs font-medium mb-1.5", style: "color: #8892A4;" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "w-full px-3 py-2.5 rounded-lg border text-sm outline-none transition-all",
              style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;",
              placeholder: "••••••••" %>
        </div>

        <%= f.hidden_field :locale, value: I18n.locale %>
        <%= f.hidden_field :currency, value: I18n.locale.to_s == "pt-BR" ? "BRL" : "USD" %>
        <%= f.submit t("devise.registrations.new.create_btn"), class: "w-full py-2.5 rounded-lg text-sm font-semibold cursor-pointer transition-colors hover:opacity-90 mt-2", style: "background-color: #6C63FF; color: white;" %>
      <% end %>

      <p class="text-center text-sm mt-4" style="color: #8892A4;">
        <%= t("devise.registrations.new.have_account") %>
        <%= link_to t("devise.registrations.new.sign_in"), new_session_path(resource_name), class: "font-medium hover:opacity-80", style: "color: #6C63FF;" %>
      </p>
    </div>
  </div>
</div>
