<div class="min-h-screen flex items-center justify-center px-4" style="background-color: #0F1117;">
  <div class="w-full max-w-sm">
    <div class="flex flex-col items-center mb-8">
      <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-3" style="background-color: #6C63FF;">
        <%= svg_icon "wallet", css_class: "w-6 h-6", stroke: "white" %>
      </div>
      <h1 class="text-2xl font-bold" style="color: #E2E8F0;"><%= t("app.name") %></h1>
      <p class="text-sm mt-1" style="color: #8892A4;"><%= t("devise.sessions.new.subtitle") %></p>
    </div>

    <div class="rounded-xl border p-6" style="background-color: #1E2130; border-color: #2A2F45;">
      <h2 class="text-base font-semibold mb-5" style="color: #E2E8F0;"><%= t("devise.sessions.new.sign_in_heading") %></h2>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
        <div>
          <%= f.label :email, class: "block text-xs font-medium mb-1.5", style: "color: #8892A4;" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full px-3 py-2.5 rounded-lg border text-sm outline-none transition-all",
              style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;",
              placeholder: "you@example.com" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-xs font-medium mb-1.5", style: "color: #8892A4;" %>
          <%= f.password_field :password, autocomplete: "current-password",
              class: "w-full px-3 py-2.5 rounded-lg border text-sm outline-none transition-all",
              style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;",
              placeholder: "••••••••" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center justify-between">
            <label class="flex items-center gap-2 text-sm cursor-pointer" style="color: #8892A4;">
              <%= f.check_box :remember_me, class: "w-4 h-4 rounded", style: "accent-color: #6C63FF;" %>
              <%= t("devise.sessions.new.remember_me") %>
            </label>
            <%= link_to t("devise.sessions.new.forgot_password"), new_password_path(resource_name), class: "text-xs hover:opacity-80", style: "color: #6C63FF;" %>
          </div>
        <% end %>

        <%= f.submit t("devise.sessions.new.sign_in"), class: "w-full py-2.5 rounded-lg text-sm font-semibold cursor-pointer transition-colors hover:opacity-90 mt-2", style: "background-color: #6C63FF; color: white;" %>
      <% end %>

      <p class="text-center text-sm mt-4" style="color: #8892A4;">
        <%= t("devise.sessions.new.no_account") %>
        <%= link_to t("devise.sessions.new.sign_up"), new_registration_path(resource_name), class: "font-medium hover:opacity-80", style: "color: #6C63FF;" %>
      </p>
    </div>
  </div>
</div>
