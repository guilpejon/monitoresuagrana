<% if resource.errors.any? %>
  <div class="px-4 py-3 rounded-lg border text-sm mb-4" style="background-color: rgba(255,107,107,0.1); border-color: #FF6B6B; color: #FF6B6B;" data-turbo-temporary>
    <ul class="space-y-1 list-disc list-inside">
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
