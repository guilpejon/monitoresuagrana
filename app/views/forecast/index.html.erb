<% provide :title, t('.title') %>
<div class="space-y-5">
  <div>
    <h1 class="text-xl font-bold" style="color: #E2E8F0;"><%= t("forecast.index.title") %></h1>
    <% if @is_past_month %>
      <p class="text-sm mt-0.5" style="color: #8892A4;"><%= t("forecast.index.actuals_for") %> <%= l(@current_date, format: "%B %Y") %></p>
    <% else %>
      <p class="text-sm mt-0.5" style="color: #8892A4;"><%= t("forecast.index.projection_for") %> <%= l(@current_date, format: "%B %Y") %></p>
    <% end %>
  </div>

  <%# Summary cards %>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <% if @is_past_month %>
      <div class="rounded-xl border p-4" style="background-color: #1E2130; border-color: #2A2F45;">
        <p class="text-xs font-medium uppercase tracking-wide mb-2" style="color: #8892A4;"><%= t("forecast.index.actual_income") %></p>
        <p class="text-xl font-bold" style="color: #00D4AA;"><%= format_currency(@actual_income_total) %></p>
        <p class="text-xs mt-1" style="color: #8892A4;"><%= link_to incomes_path, class: "hover:opacity-80 transition-opacity", style: "color: #00D4AA;" do %><%= @actual_incomes.count %> <%= @actual_incomes.count == 1 ? t("forecast.index.income_source") : t("forecast.index.income_sources") %><% end %></p>
      </div>
      <div class="rounded-xl border p-4" style="background-color: #1E2130; border-color: #2A2F45;">
        <p class="text-xs font-medium uppercase tracking-wide mb-2" style="color: #8892A4;"><%= t("forecast.index.actual_expenses") %></p>
        <p class="text-xl font-bold" style="color: #FF6B6B;"><%= format_currency(@actual_total) %></p>
        <p class="text-xs mt-1" style="color: #8892A4;"><%= link_to "#{@actual_expenses.count} #{t("forecast.index.transactions")}", expenses_path, class: "hover:opacity-80 transition-opacity", style: "color: #FF6B6B;" %></p>
      </div>
      <div class="rounded-xl border p-4" style="background-color: #1E2130; border-color: #2A2F45;">
        <p class="text-xs font-medium uppercase tracking-wide mb-2" style="color: #8892A4;"><%= t("forecast.index.actual_balance") %></p>
        <p class="text-xl font-bold" style="color: <%= @actual_balance >= 0 ? '#00D4AA' : '#FF6B6B' %>;"><%= format_currency(@actual_balance) %></p>
        <p class="text-xs mt-1" style="color: #8892A4;"><%= t("forecast.index.vs") %> <%= format_currency(@prev_month_balance) %> <%= t("forecast.index.in") %> <%= @prev_month_label %></p>
      </div>
    <% else %>
      <div class="rounded-xl border p-4" style="background-color: #1E2130; border-color: #2A2F45;">
        <p class="text-xs font-medium uppercase tracking-wide mb-2" style="color: #8892A4;"><%= t("forecast.index.projected_income") %></p>
        <p class="text-xl font-bold" style="color: #00D4AA;"><%= format_currency(@projected_income) %></p>
        <p class="text-xs mt-1" style="color: #8892A4;"><%= link_to incomes_path, class: "hover:opacity-80 transition-opacity", style: "color: #00D4AA;" do %><%= @projected_incomes.count %> <%= @projected_incomes.count == 1 ? t("forecast.index.recurring_source") : t("forecast.index.recurring_sources") %><% end %></p>
      </div>
      <div class="rounded-xl border p-4" style="background-color: #1E2130; border-color: #2A2F45;">
        <p class="text-xs font-medium uppercase tracking-wide mb-2" style="color: #8892A4;"><%= t("forecast.index.projected_expenses") %></p>
        <p class="text-xl font-bold" style="color: #FF6B6B;"><%= format_currency(@projected_total) %></p>
        <p class="text-xs mt-1" style="color: #8892A4;"><%= link_to expenses_path, class: "hover:opacity-80 transition-opacity", style: "color: #FF6B6B;" do %><%= @recurring_expenses.count %> <%= t("forecast.index.recurring", count: @recurring_expenses.count) %><% if @installment_expenses.any? %> · <%= @installment_expenses.count %> <%= t("forecast.index.installment", count: @installment_expenses.count) %><% end %><% end %></p>
      </div>
      <div class="rounded-xl border p-4" style="background-color: #1E2130; border-color: #2A2F45;">
        <p class="text-xs font-medium uppercase tracking-wide mb-2" style="color: #8892A4;"><%= t("forecast.index.projected_balance") %></p>
        <p class="text-xl font-bold" style="color: <%= @projected_balance >= 0 ? '#00D4AA' : '#FF6B6B' %>;"><%= format_currency(@projected_balance) %></p>
        <p class="text-xs mt-1" style="color: #8892A4;"><%= t("forecast.index.vs") %> <%= format_currency(@prev_month_balance) %> <%= t("forecast.index.in") %> <%= @prev_month_label %></p>
      </div>
    <% end %>
  </div>

  <%# Monthly spending progress line chart %>
  <div class="rounded-xl border p-5" style="background-color: #1E2130; border-color: #2A2F45;" data-currency-axis="y" data-gradient-lines>
    <h2 class="text-sm font-semibold mb-4" style="color: #E2E8F0;">
      <%= t("forecast.index.monthly_spending_trend") %>
    </h2>
    <%= line_chart @monthly_spending_chart_data,
        colors: ["#FF6B6B", "#00D4AA"],
        library: {
          plugins: {
            legend: { display: true, labels: { color: "#8892A4", boxWidth: 12 } }
          },
          scales: {
            x: { ticks: { color: "#8892A4" }, grid: { color: "#2A2F45" }, title: { display: true, text: t("forecast.index.day_of_month"), color: "#8892A4" } },
            y: { ticks: { color: "#8892A4" }, grid: { color: "#2A2F45" } }
          }
        } %>
  </div>

  <%# Chart %>
  <div class="rounded-xl border p-5" style="background-color: #1E2130; border-color: #2A2F45;" data-currency-axis="x">
    <h2 class="text-sm font-semibold mb-4" style="color: #E2E8F0;">
      <%= @is_past_month ? t("forecast.index.actual_by_category") : t("forecast.index.projected_by_category") %>
    </h2>
    <% if @forecast_chart_data.any? %>
      <%= bar_chart @forecast_chart_data,
          colors: @forecast_chart_colors,
          library: {
            indexAxis: "y",
            plugins: { legend: { display: false } },
            scales: {
              x: { ticks: { color: "#8892A4" }, grid: { color: "#2A2F45" } },
              y: { ticks: { color: "#8892A4" }, grid: { color: "#2A2F45" } }
            }
          } %>
    <% else %>
      <%= render "shared/empty_state", message: @is_past_month ? t("forecast.index.no_expenses_month") : t("forecast.index.no_recurring") %>
    <% end %>
  </div>


  <%# Credit card bills %>
  <% if @credit_card_bills.any? %>
    <div class="rounded-xl border overflow-hidden" style="background-color: #1E2130; border-color: #2A2F45;">
      <div class="px-4 py-3 border-b" style="border-color: #2A2F45;">
        <h2 class="text-sm font-semibold" style="color: #E2E8F0;"><%= t("forecast.index.credit_card_bills") %></h2>
      </div>
      <div class="divide-y" style="border-color: #2A2F45;">
        <% @credit_card_bills.each do |card, total| %>
          <div class="flex items-center gap-3 px-4 py-3">
            <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background-color: <%= card.color_hex %>22;">
              <%= svg_icon "credit-card", css_class: "w-4 h-4", stroke: card.color_hex %>
            </div>
            <p class="flex-1 text-sm font-medium" style="color: #E2E8F0;"><%= card.name %></p>
            <span class="text-sm font-semibold" style="color: #FF6B6B;"><%= format_currency(total) %></span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Previous month comparison %>
  <% if @prev_month_by_category.any? %>
    <div class="rounded-xl border overflow-hidden" style="background-color: #1E2130; border-color: #2A2F45;">
      <div class="px-4 py-3 border-b" style="border-color: #2A2F45;">
        <h2 class="text-sm font-semibold" style="color: #E2E8F0;"><%= t("forecast.index.actuals") %> <%= @prev_month_label %></h2>
      </div>
      <div class="divide-y" style="border-color: #2A2F45;">
        <% @prev_month_by_category.sort_by { |_, v| -v }.first(6).each do |cat_name, amount| %>
          <div class="flex items-center justify-between gap-3 px-4 py-3">
            <span class="text-sm" style="color: #E2E8F0;"><%= cat_name %></span>
            <span class="text-sm font-semibold" style="color: #FF6B6B;"><%= format_currency(amount) %></span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
