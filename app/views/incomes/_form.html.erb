<%= form_with model: income, class: "space-y-4" do |f| %>
  <% if income.errors.any? %>
    <div class="px-4 py-3 rounded-lg border text-sm" style="background-color: rgba(255,107,107,0.1); border-color: #FF6B6B; color: #FF6B6B;">
      <ul class="space-y-1">
        <% income.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;">Description *</label>
    <%= f.text_field :description, class: "w-full px-3 py-2.5 rounded-lg border text-sm outline-none transition-all", style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;", placeholder: "e.g. Monthly Salary", autofocus: true %>
  </div>

  <div>
    <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;">Amount *</label>
    <div class="relative">
      <span class="absolute left-3 top-1/2 -translate-y-1/2 text-sm font-medium" style="color: #8892A4;">R$</span>
      <%= f.number_field :amount, step: "0.01", min: "0", class: "w-full pl-9 pr-3 py-2.5 rounded-lg border text-sm font-semibold outline-none transition-all", style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;", placeholder: "0,00" %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-3">
    <div>
      <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;">Date *</label>
      <%= f.date_field :date, class: "w-full px-3 py-2.5 rounded-lg border text-sm outline-none transition-all", style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;" %>
    </div>
    <div>
      <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;">Type</label>
      <%= f.select :income_type,
          [["Salary", "salary"], ["Freelance", "freelance"], ["Dividend", "dividend"], ["Other", "other"]],
          {},
          class: "w-full px-3 py-2.5 rounded-lg border text-sm outline-none transition-all",
          style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;" %>
    </div>
  </div>

  <div class="flex items-center gap-3">
    <%= f.check_box :recurring, class: "w-4 h-4 rounded", style: "accent-color: #6C63FF;" %>
    <label class="text-sm" style="color: #8892A4;">Recurring income</label>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit income.new_record? ? "Add Income" : "Update Income", class: "flex-1 py-2.5 rounded-lg text-sm font-semibold cursor-pointer transition-colors hover:opacity-90", style: "background-color: #6C63FF; color: white;" %>
    <%= link_to "Cancel", incomes_path, class: "px-4 py-2.5 rounded-lg text-sm font-medium transition-colors hover:bg-white/5", style: "color: #8892A4;" %>
  </div>
<% end %>
