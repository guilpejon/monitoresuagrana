<div id="income_<%= income.id %>" class="flex items-center gap-3 px-4 py-3 hover:bg-white/[0.02] transition-colors">
  <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background-color: rgba(0,212,170,0.15);">
    <%= svg_icon "wallet", css_class: "w-4 h-4", stroke: "#00D4AA" %>
  </div>

  <div class="flex-1 min-w-0">
    <p class="text-sm font-medium truncate" style="color: #E2E8F0;"><%= income.description %></p>
    <div class="flex items-center gap-2 mt-0.5">
      <span class="text-xs" style="color: #8892A4;"><%= income.date.strftime("%d %b %Y") %></span>
      <span class="text-xs" style="color: #2A2F45;">·</span>
      <%= income_type_badge(income.income_type) %>
      <% if income.recurring? %>
        <%= svg_icon "repeat", css_class: "w-3.5 h-3.5", stroke: "#8892A4" %>
      <% end %>
    </div>
  </div>

  <span class="text-sm font-semibold flex-shrink-0" style="color: #00D4AA;"><%= format_brl(income.amount) %></span>

  <div class="flex items-center gap-1">
    <%= link_to edit_income_path(income), class: "p-1.5 rounded-lg hover:bg-white/5 transition-colors", style: "color: #8892A4;" do %>
      <%= svg_icon "edit", css_class: "w-3.5 h-3.5" %>
    <% end %>
    <%= button_to income_path(income), method: :delete,
        form: { data: { turbo_confirm: "Delete this income?" } },
        class: "p-1.5 rounded-lg hover:bg-white/5 transition-colors", style: "color: #8892A4; background: none; border: none; cursor: pointer;" do %>
      <%= svg_icon "trash-2", css_class: "w-3.5 h-3.5" %>
    <% end %>
  </div>
</div>
