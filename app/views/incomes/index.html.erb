<% provide :title, t('.title') %>
<div class="space-y-4">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-xl font-bold" style="color: #E2E8F0;"><%= t("incomes.index.title") %></h1>
      <p class="text-sm mt-0.5" style="color: #8892A4;">
        <%= t("incomes.index.total") %> <span class="font-semibold" style="color: #00D4AA;"><%= format_currency(@total) %></span>
      </p>
    </div>
    <%= link_to new_income_path, class: "flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold transition-colors hover:opacity-90", style: "background-color: #6C63FF; color: white;" do %>
      <%= svg_icon "plus", css_class: "w-4 h-4", stroke: "white" %>
      <%= t("incomes.index.add") %>
    <% end %>
  </div>

  <div class="rounded-xl border overflow-hidden" style="background-color: #1E2130; border-color: #2A2F45;">
    <% if @incomes.any? %>
      <div id="incomes_list" class="divide-y" style="border-color: #2A2F45;">
        <% @incomes.each do |income| %>
          <%= render "income", income: income %>
        <% end %>
      </div>
    <% else %>
      <div id="incomes_list" class="flex flex-col items-center justify-center py-16 gap-3">
        <%= svg_icon "wallet", css_class: "w-12 h-12 opacity-20", stroke: "#8892A4" %>
        <p class="text-sm font-medium" style="color: #8892A4;"><%= t("incomes.index.no_income") %></p>
        <%= link_to t("incomes.index.add_first"), new_income_path, class: "text-sm font-medium hover:opacity-80", style: "color: #6C63FF;" %>
      </div>
    <% end %>
  </div>

  <% if @pagy.pages > 1 %>
    <div class="flex justify-center">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>
</div>

<div id="incomes_total" class="hidden"></div>
