<% provide :title, t('.title') %>
<div class="space-y-5">
  <div class="flex items-center justify-between">
    <h1 class="text-xl font-bold" style="color: #E2E8F0;"><%= t("bank_accounts.index.title") %></h1>
    <div class="flex items-center gap-2">
      <%= link_to new_bank_account_path, class: "flex items-center gap-2 px-3 sm:px-4 py-2 rounded-lg text-sm font-semibold transition-colors hover:opacity-90", style: "background-color: #6C63FF; color: white;" do %>
        <%= svg_icon "plus", css_class: "w-4 h-4", stroke: "white" %>
        <span class="hidden sm:inline"><%= t("bank_accounts.index.add") %></span>
      <% end %>
    </div>
  </div>

  <%# CDI banner %>
  <% if @cdi_info %>
    <div class="rounded-xl border px-4 py-3 flex items-center gap-3" style="background-color: rgba(0,212,170,0.08); border-color: rgba(0,212,170,0.3);">
      <div class="flex-1">
        <p class="text-xs font-medium uppercase tracking-wide mb-0.5" style="color: #00D4AA;"><%= t("bank_accounts.index.cdi_rate_annual") %></p>
        <p class="text-sm font-semibold" style="color: #E2E8F0;">
          <%= number_with_precision(@cdi_info[:rate], precision: 2) %><%= t("bank_accounts.index.cdi_pa") %>
          <span class="text-xs font-normal ml-2" style="color: #8892A4;">
            <%= t("bank_accounts.index.as_of") %> <%= @cdi_info[:date] %> &middot; <%= t("bank_accounts.index.updated") %> <%= time_ago_in_words(@cdi_info[:updated_at]) %> <%= t("bank_accounts.index.ago") %>
          </span>
        </p>
      </div>
    </div>
  <% else %>
    <div class="rounded-xl border px-4 py-3 flex items-center gap-3" style="background-color: rgba(247,183,49,0.08); border-color: rgba(247,183,49,0.3);">
      <p class="text-sm" style="color: #F7B731;"><%= t("bank_accounts.index.cdi_not_cached") %></p>
    </div>
  <% end %>

  <%# Summary cards %>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <div class="rounded-xl border p-4" style="background-color: #1E2130; border-color: #2A2F45;">
      <p class="text-xs font-medium uppercase tracking-wide mb-2" style="color: #8892A4;"><%= t("bank_accounts.index.total_balance") %></p>
      <p class="text-lg font-bold" style="color: #E2E8F0;"><%= format_currency(@total_balance) %></p>
    </div>
    <div class="rounded-xl border p-4" style="background-color: #1E2130; border-color: #2A2F45;">
      <p class="text-xs font-medium uppercase tracking-wide mb-2" style="color: #8892A4;"><%= t("bank_accounts.index.est_monthly_interest") %></p>
      <p class="text-lg font-bold" style="color: #00D4AA;"><%= format_currency(@total_monthly_interest) %></p>
    </div>
    <div class="rounded-xl border p-4" style="background-color: #1E2130; border-color: #2A2F45;">
      <p class="text-xs font-medium uppercase tracking-wide mb-2" style="color: #8892A4;"><%= t("bank_accounts.index.est_yearly_interest") %></p>
      <p class="text-lg font-bold" style="color: #00D4AA;"><%= format_currency(@total_yearly_interest) %></p>
    </div>
  </div>

  <%# Accounts by type %>
  <% if @bank_accounts.any? %>
    <% @by_type.each do |type, accounts| %>
      <div class="rounded-xl border overflow-hidden" style="background-color: #1E2130; border-color: #2A2F45;">
        <div class="px-4 py-3 border-b" style="border-color: #2A2F45; background-color: rgba(42,47,69,0.4);">
          <div class="flex items-center justify-between">
            <h2 class="text-sm font-semibold capitalize" style="color: #E2E8F0;">
              <%= t("bank_accounts.form.#{type}") %>
              <span class="ml-2 text-xs font-normal" style="color: #8892A4;"><%= accounts.count %></span>
            </h2>
            <span class="text-sm font-semibold" style="color: #E2E8F0;"><%= format_currency(accounts.sum(&:balance)) %></span>
          </div>
        </div>

        <%# Table header %>
        <div class="hidden md:grid grid-cols-6 gap-3 px-4 py-2 text-xs font-medium uppercase tracking-wide border-b" style="color: #8892A4; border-color: #2A2F45;">
          <div class="col-span-2"><%= t("bank_accounts.index.name") %></div>
          <div><%= t("bank_accounts.index.bank") %></div>
          <div class="text-right"><%= t("bank_accounts.index.balance") %></div>
          <div class="text-right"><%= t("bank_accounts.index.interest_rate") %></div>
          <div class="text-right"><%= t("bank_accounts.index.actions") %></div>
        </div>

        <div class="divide-y" style="border-color: #2A2F45;">
          <% accounts.each do |account| %>
            <% is_default = current_user.default_bank_account_id == account.id %>
            <div class="px-4 py-3 hover:bg-white/[0.02] transition-colors">
              <div class="flex items-center justify-between md:grid md:grid-cols-6 md:gap-3">
                <%# Name %>
                <div class="col-span-2 flex items-center gap-2 min-w-0">
                  <div class="w-8 h-8 rounded-lg flex-shrink-0" style="background-color: <%= account.color %>;"></div>
                  <div class="min-w-0">
                    <div class="flex items-center gap-2">
                      <p class="text-sm font-medium truncate" style="color: #E2E8F0;"><%= account.name %></p>
                      <% if is_default %>
                        <span class="text-xs font-semibold px-1.5 py-0.5 rounded-full flex-shrink-0" style="background-color: #6C63FF22; color: #6C63FF; border: 1px solid #6C63FF44;"><%= t("bank_accounts.index.default_badge") %></span>
                      <% end %>
                    </div>
                    <p class="text-xs md:hidden" style="color: #8892A4;"><%= account.bank_name.presence || "—" %></p>
                  </div>
                </div>

                <%# Mobile: show balance %>
                <div class="md:hidden flex flex-col items-end gap-0.5">
                  <span class="text-sm font-semibold" style="color: #E2E8F0;"><%= format_currency(account.balance) %></span>
                  <% if account.cdi_percentage? %>
                    <span class="text-xs" style="color: #00D4AA;"><%= number_with_precision(account.cdi_multiplier, precision: 0) %>% CDI</span>
                  <% elsif account.interest_rate > 0 %>
                    <span class="text-xs" style="color: #00D4AA;"><%= account.interest_rate %><%= t("bank_accounts.index.cdi_pa") %></span>
                  <% end %>
                </div>

                <%# Desktop columns %>
                <div class="hidden md:block">
                  <span class="text-sm" style="color: #8892A4;"><%= account.bank_name.presence || "—" %></span>
                </div>
                <div class="hidden md:block text-right">
                  <span class="text-sm font-semibold" style="color: #E2E8F0;"><%= format_currency(account.balance) %></span>
                </div>
                <div class="hidden md:block text-right">
                  <% if account.cdi_percentage? %>
                    <span class="text-sm" style="color: #00D4AA;"><%= number_with_precision(account.cdi_multiplier, precision: 0) %>% CDI</span>
                    <% if @cdi_rate %>
                      <p class="text-xs" style="color: #8892A4;">&#8776; <%= number_with_precision(account.effective_rate, precision: 2) %><%= t("bank_accounts.index.cdi_pa") %></p>
                    <% end %>
                  <% elsif account.interest_rate > 0 %>
                    <span class="text-sm" style="color: #00D4AA;"><%= account.interest_rate %><%= t("bank_accounts.index.cdi_pa") %></span>
                  <% else %>
                    <span class="text-sm" style="color: #8892A4;">—</span>
                  <% end %>
                </div>
                <div class="hidden md:flex items-center justify-end gap-1">
                  <%= button_to set_default_bank_account_path(account), method: :patch,
                      class: "flex items-center gap-1 p-1.5 rounded-lg hover:bg-white/5 transition-colors",
                      style: "border: none; background: none; cursor: pointer; color: #{is_default ? '#6C63FF' : '#8892A4'};" do %>
                    <%= svg_icon "star", css_class: "w-3.5 h-3.5" %>
                  <% end %>
                  <%= link_to edit_bank_account_path(account), class: "p-1.5 rounded-lg hover:bg-white/5 transition-colors", style: "color: #8892A4;" do %>
                    <%= svg_icon "edit", css_class: "w-3.5 h-3.5" %>
                  <% end %>
                  <%= render "shared/delete_modal_button",
                      path: bank_account_path(account),
                      title: t("bank_accounts.index.delete_modal_title"),
                      question: t("bank_accounts.index.delete_confirm"),
                      confirm_label: t("shared.delete_modal.confirm"),
                      cancel_label: t("shared.delete_modal.cancel") %>
                </div>
              </div>

              <%# Mobile actions %>
              <div class="flex items-center justify-end gap-1 mt-1 md:hidden">
                <%= button_to set_default_bank_account_path(account), method: :patch,
                    class: "flex items-center gap-1 p-1.5 rounded-lg hover:bg-white/5 transition-colors",
                    style: "border: none; background: none; cursor: pointer; color: #{is_default ? '#6C63FF' : '#8892A4'};" do %>
                  <%= svg_icon "star", css_class: "w-3.5 h-3.5" %>
                <% end %>
                <%= link_to edit_bank_account_path(account), class: "p-1.5 rounded-lg hover:bg-white/5 transition-colors", style: "color: #8892A4;" do %>
                  <%= svg_icon "edit", css_class: "w-3.5 h-3.5" %>
                <% end %>
                <%= render "shared/delete_modal_button",
                    path: bank_account_path(account),
                    title: t("bank_accounts.index.delete_modal_title"),
                    question: t("bank_accounts.index.delete_confirm"),
                    confirm_label: t("shared.delete_modal.confirm"),
                    cancel_label: t("shared.delete_modal.cancel") %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="rounded-xl border flex flex-col items-center justify-center py-16 gap-3" style="background-color: #1E2130; border-color: #2A2F45;">
      <%= svg_icon "landmark", css_class: "w-12 h-12 opacity-20", stroke: "#8892A4" %>
      <p class="text-sm font-medium" style="color: #8892A4;"><%= t("bank_accounts.index.no_accounts") %></p>
      <%= link_to t("bank_accounts.index.add_first"), new_bank_account_path, class: "text-sm font-medium hover:opacity-80", style: "color: #6C63FF;" %>
    </div>
  <% end %>
</div>
