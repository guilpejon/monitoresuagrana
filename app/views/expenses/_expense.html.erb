<div id="expense_<%= expense.id %>" class="flex items-center gap-3 px-4 py-3 hover:bg-white/[0.02] transition-colors">
  <%# Category icon %>
  <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background-color: <%= expense.category.color %>22;">
    <%= svg_icon expense.category.icon, css_class: "w-4 h-4", stroke: expense.category.color %>
  </div>

  <%# Details %>
  <div class="flex-1 min-w-0">
    <p class="text-sm font-medium truncate" style="color: #E2E8F0;"><%= expense.description %></p>
    <div class="flex items-center gap-2 mt-0.5">
      <span class="text-xs" style="color: #8892A4;"><%= expense.date.strftime("%d %b %Y") %></span>
      <span class="text-xs" style="color: #2A2F45;">·</span>
      <span class="text-xs" style="color: #8892A4;"><%= expense.category.name %></span>
      <% if expense.credit_card %>
        <span class="text-xs" style="color: #2A2F45;">·</span>
        <%= svg_icon "credit-card", css_class: "w-3 h-3 inline", stroke: "#8892A4" %>
        <span class="text-xs" style="color: #8892A4;"><%= expense.credit_card.name %></span>
      <% end %>
    </div>
  </div>

  <%# Type badge + amount %>
  <div class="flex items-center gap-3 flex-shrink-0">
    <%= expense_type_badge(expense.expense_type) %>
    <% if expense.recurring? %>
      <%= svg_icon "repeat", css_class: "w-3.5 h-3.5", stroke: "#8892A4" %>
    <% end %>
    <span class="text-sm font-semibold min-w-20 text-right" style="color: #FF6B6B;"><%= format_brl(expense.amount) %></span>
  </div>

  <%# Actions %>
  <div class="flex items-center gap-1">
    <%= link_to edit_expense_path(expense), class: "p-1.5 rounded-lg hover:bg-white/5 transition-colors", style: "color: #8892A4;" do %>
      <%= svg_icon "edit", css_class: "w-3.5 h-3.5" %>
    <% end %>
    <%= button_to expense_path(expense), method: :delete,
        form: { data: { turbo_confirm: "Delete this expense?" } },
        class: "p-1.5 rounded-lg hover:bg-white/5 transition-colors", style: "color: #8892A4; background: none; border: none; cursor: pointer;" do %>
      <%= svg_icon "trash-2", css_class: "w-3.5 h-3.5" %>
    <% end %>
  </div>
</div>
