<% provide :title, t('.title') %>
<div class="space-y-4" data-controller="expense-filter" data-currency="<%= current_user.currency || 'BRL' %>">
  <%# Header %>
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-xl font-bold" style="color: #E2E8F0;"><%= t("expenses.index.title") %></h1>
      <p class="text-sm mt-0.5" style="color: #8892A4;">
        <%= t("expenses.index.total") %> <span class="font-semibold" style="color: #FF6B6B;" id="expenses-total-amount" data-expense-filter-target="grandTotal"><%= format_currency(@total) %></span>
      </p>
    </div>
    <%= link_to new_expense_path, class: "flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold transition-colors hover:opacity-90", style: "background-color: #6C63FF; color: white;" do %>
      <%= svg_icon "plus", css_class: "w-4 h-4", stroke: "white" %>
      <span class="hidden sm:inline"><%= t("expenses.index.add_expense") %></span>
      <span class="sm:hidden"><%= t("expenses.index.add_expense_short") %></span>
    <% end %>
  </div>

  <%# Search bar %>
  <div class="relative">
    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
      <%= svg_icon "search", css_class: "w-4 h-4", stroke: "#8892A4" %>
    </div>
    <input type="text"
           data-expense-filter-target="input"
           data-action="input->expense-filter#filter"
           placeholder="<%= t('expenses.index.search_placeholder') %>"
           class="w-full pl-9 pr-9 py-2.5 rounded-xl text-sm outline-none transition-colors"
           style="background-color: #1E2130; border: 1px solid #2A2F45; color: #E2E8F0;"
           autocomplete="off" />
    <button type="button"
            data-expense-filter-target="clear"
            data-action="click->expense-filter#clear"
            class="absolute inset-y-0 right-0 pr-3 flex items-center transition-colors hover:opacity-70"
            hidden>
      <%= svg_icon "x", css_class: "w-4 h-4", stroke: "#8892A4" %>
    </button>
  </div>

  <%# Fixed expenses %>
  <div class="rounded-xl border overflow-hidden" style="background-color: #1E2130; border-color: #2A2F45;">
    <div class="px-4 py-3 border-b flex items-center justify-between" style="border-color: #2A2F45;">
      <h2 class="text-sm font-semibold" style="color: #E2E8F0;"><%= t("expenses.index.fixed_expenses") %></h2>
      <span class="text-sm font-semibold" style="color: #FF6B6B;" data-expense-filter-target="fixedTotal"><%= format_currency(@fixed_total) %></span>
    </div>
    <% if @fixed_expenses.any? %>
      <div id="fixed_expenses_list" class="divide-y" style="border-color: #2A2F45;">
        <% @fixed_expenses.each do |expense| %>
          <%= render "expense", expense: expense %>
        <% end %>
        <div data-expense-filter-target="fixedEmpty" hidden class="flex flex-col items-center justify-center py-10 gap-2">
          <p class="text-sm" style="color: #8892A4;"><%= t("expenses.index.no_results") %></p>
        </div>
      </div>
    <% else %>
      <div id="fixed_expenses_list">
        <div class="flex flex-col items-center justify-center py-10 gap-2">
          <p class="text-sm" style="color: #8892A4;"><%= t("expenses.index.no_fixed_expenses") %></p>
        </div>
      </div>
    <% end %>
  </div>

  <%# Installment expenses %>
  <% if @variable_installment_expenses.any? %>
    <div class="rounded-xl border overflow-hidden" style="background-color: #1E2130; border-color: #2A2F45;">
      <div class="px-4 py-3 border-b flex items-center justify-between" style="border-color: #2A2F45;">
        <h2 class="text-sm font-semibold" style="color: #E2E8F0;"><%= t("expenses.index.installment_expenses") %></h2>
        <span class="text-sm font-semibold" style="color: #FF6B6B;" data-expense-filter-target="installmentTotal"><%= format_currency(@variable_installment_total) %></span>
      </div>
      <div id="installment_expenses_list" class="divide-y" style="border-color: #2A2F45;">
        <% @variable_installment_expenses.each do |expense| %>
          <%= render "expense", expense: expense %>
        <% end %>
        <div data-expense-filter-target="installmentEmpty" hidden class="flex flex-col items-center justify-center py-10 gap-2">
          <p class="text-sm" style="color: #8892A4;"><%= t("expenses.index.no_results") %></p>
        </div>
      </div>
    </div>
  <% end %>

  <%# Variable other expenses %>
  <div class="rounded-xl border overflow-hidden" style="background-color: #1E2130; border-color: #2A2F45;">
    <div class="px-4 py-3 border-b flex items-center justify-between" style="border-color: #2A2F45;">
      <h2 class="text-sm font-semibold" style="color: #E2E8F0;"><%= t("expenses.index.variable_other") %></h2>
      <span class="text-sm font-semibold" style="color: #FF6B6B;" data-expense-filter-target="regularTotal"><%= format_currency(@variable_regular_total) %></span>
    </div>
    <% if @variable_regular_expenses.any? %>
      <div id="variable_expenses_list" class="divide-y" style="border-color: #2A2F45;">
        <% @variable_regular_expenses.each do |expense| %>
          <%= render "expense", expense: expense %>
        <% end %>
        <div data-expense-filter-target="variableEmpty" hidden class="flex flex-col items-center justify-center py-10 gap-2">
          <p class="text-sm" style="color: #8892A4;"><%= t("expenses.index.no_results") %></p>
        </div>
      </div>
    <% else %>
      <div id="variable_expenses_list">
        <div class="flex flex-col items-center justify-center py-10 gap-2">
          <p class="text-sm" style="color: #8892A4;"><%= t("expenses.index.no_variable_expenses") %></p>
          <%= link_to t("expenses.index.add_first"), new_expense_path, class: "text-sm font-medium hover:opacity-80", style: "color: #6C63FF;" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<div id="expenses_total" class="hidden"></div>
