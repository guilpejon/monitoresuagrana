<% provide :title, t('.title') %>
<div class="space-y-4">
  <%# Header %>
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-xl font-bold" style="color: #E2E8F0;"><%= t("expenses.index.title") %></h1>
      <p class="text-sm mt-0.5" style="color: #8892A4;">
        <%= t("expenses.index.total") %> <span class="font-semibold" style="color: #FF6B6B;" id="expenses-total-amount"><%= format_currency(@total) %></span>
      </p>
    </div>
    <%= link_to new_expense_path, class: "flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold transition-colors hover:opacity-90", style: "background-color: #6C63FF; color: white;" do %>
      <%= svg_icon "plus", css_class: "w-4 h-4", stroke: "white" %>
      <%= t("expenses.index.add_expense") %>
    <% end %>
  </div>

  <%# Fixed expenses %>
  <div class="rounded-xl border overflow-hidden" style="background-color: #1E2130; border-color: #2A2F45;">
    <div class="px-4 py-3 border-b flex items-center justify-between" style="border-color: #2A2F45;">
      <h2 class="text-sm font-semibold" style="color: #E2E8F0;"><%= t("expenses.index.fixed_expenses") %></h2>
      <span class="text-sm font-semibold" style="color: #FF6B6B;"><%= format_currency(@fixed_total) %></span>
    </div>
    <% if @fixed_expenses.any? %>
      <div id="fixed_expenses_list" class="divide-y" style="border-color: #2A2F45;">
        <% @fixed_expenses.each do |expense| %>
          <%= render "expense", expense: expense %>
        <% end %>
      </div>
    <% else %>
      <div id="fixed_expenses_list">
        <div class="flex flex-col items-center justify-center py-10 gap-2">
          <p class="text-sm" style="color: #8892A4;"><%= t("expenses.index.no_fixed_expenses") %></p>
        </div>
      </div>
    <% end %>
  </div>

  <%# Fixed pagination %>
  <% if @pagy_fixed.pages > 1 %>
    <div class="flex justify-center">
      <%== @pagy_fixed.series_nav %>
    </div>
  <% end %>

  <%# Variable expenses %>
  <div class="rounded-xl border overflow-hidden" style="background-color: #1E2130; border-color: #2A2F45;">
    <div class="px-4 py-3 border-b flex items-center justify-between" style="border-color: #2A2F45;">
      <h2 class="text-sm font-semibold" style="color: #E2E8F0;"><%= t("expenses.index.variable_expenses") %></h2>
      <span class="text-sm font-semibold" style="color: #FF6B6B;"><%= format_currency(@variable_total) %></span>
    </div>
    <% if @variable_expenses.any? %>
      <div id="variable_expenses_list" class="divide-y" style="border-color: #2A2F45;">
        <% @variable_expenses.each do |expense| %>
          <%= render "expense", expense: expense %>
        <% end %>
      </div>
    <% else %>
      <div id="variable_expenses_list">
        <div class="flex flex-col items-center justify-center py-10 gap-2">
          <p class="text-sm" style="color: #8892A4;"><%= t("expenses.index.no_variable_expenses") %></p>
          <%= link_to t("expenses.index.add_first"), new_expense_path, class: "text-sm font-medium hover:opacity-80", style: "color: #6C63FF;" %>
        </div>
      </div>
    <% end %>
  </div>

  <%# Variable pagination %>
  <% if @pagy_variable.pages > 1 %>
    <div class="flex justify-center">
      <%== @pagy_variable.series_nav %>
    </div>
  <% end %>
</div>

<div id="expenses_total" class="hidden"></div>
