<%= form_with model: expense, class: "space-y-4", data: { controller: "expense-payment" } do |f| %>
  <% if expense.errors.any? %>
    <div class="px-4 py-3 rounded-lg border text-sm" style="background-color: rgba(255,107,107,0.1); border-color: #FF6B6B; color: #FF6B6B;">
      <ul class="space-y-1">
        <% expense.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Amount %>
  <div>
    <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;">Amount *</label>
    <div class="relative">
      <span class="absolute left-3 top-1/2 -translate-y-1/2 text-sm font-medium" style="color: #8892A4;">R$</span>
      <%= f.number_field :amount, step: "0.01", min: "0",
          class: "w-full pl-9 pr-3 py-2.5 rounded-lg border text-sm font-semibold outline-none focus:ring-2 transition-all",
          style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;",
          placeholder: "0,00", autofocus: true,
          data: { expense_payment_target: "amount", action: "input->expense-payment#updatePerInstallment" } %>
    </div>
  </div>

  <%# Payment Method %>
  <div>
    <label class="block text-xs font-medium mb-2" style="color: #8892A4;">Payment Method</label>
    <div class="grid grid-cols-4 gap-2">
      <% [["Cash", "cash"], ["PIX", "pix"], ["Boleto", "boleto"], ["Credit Card", "credit_card"]].each do |label, value| %>
        <label class="cursor-pointer">
          <%= f.radio_button :payment_method, value,
              class: "sr-only peer",
              id: "pm_#{value}",
              checked: (expense.payment_method == value || (expense.payment_method.blank? && value == "cash")),
              data: { action: "change->expense-payment#methodChanged" } %>
          <div class="flex flex-col items-center gap-1 p-2 rounded-lg border transition-all peer-checked:border-accent text-center"
               style="border-color: #2A2F45;">
            <span class="text-xs font-medium" style="color: #8892A4;"><%= label %></span>
          </div>
        </label>
      <% end %>
    </div>
  </div>

  <%# Category %>
  <div>
    <label class="block text-xs font-medium mb-2" style="color: #8892A4;">Category *</label>
    <div class="grid grid-cols-4 gap-2">
      <% categories.each do |cat| %>
        <label class="cursor-pointer">
          <%= f.radio_button :category_id, cat.id, class: "sr-only peer", id: "cat_#{cat.id}" %>
          <div class="flex flex-col items-center gap-1 p-2 rounded-lg border transition-all peer-checked:border-accent"
               style="border-color: #2A2F45;"
               data-category-id="<%= cat.id %>"
               id="cat_label_<%= cat.id %>">
            <div class="w-7 h-7 rounded-lg flex items-center justify-center" style="background-color: <%= cat.color %>22;">
              <%= svg_icon cat.icon, css_class: "w-3.5 h-3.5", stroke: cat.color %>
            </div>
            <span class="text-xs text-center leading-tight" style="color: #8892A4;"><%= cat.name %></span>
          </div>
        </label>
      <% end %>
    </div>
  </div>

  <%# Description %>
  <div>
    <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;">Description</label>
    <%= f.text_field :description,
        class: "w-full px-3 py-2.5 rounded-lg border text-sm outline-none focus:ring-2 transition-all",
        style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;",
        placeholder: "What did you spend on?" %>
  </div>

  <%# Secondary fields %>
  <div class="grid grid-cols-2 gap-3">
    <%# Date %>
    <div>
      <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;">Date</label>
      <div class="relative">
        <%= f.date_field :date,
            type: "text",
            class: "w-full pl-3 pr-9 py-2.5 rounded-lg border text-sm outline-none focus:ring-2 transition-all",
            style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;",
            data: { controller: "datepicker" } %>
        <span class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2" style="color: #8892A4;">
          <%= svg_icon "calendar", css_class: "w-4 h-4" %>
        </span>
      </div>
    </div>

    <%# Type %>
    <div>
      <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;">Type</label>
      <%= f.select :expense_type,
          [["Variable", "variable"], ["Fixed", "fixed"]],
          {},
          class: "w-full px-3 py-2.5 rounded-lg border text-sm outline-none focus:ring-2 transition-all",
          style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;" %>
    </div>
  </div>

  <%# Credit Card picker (shown only when Credit Card selected) %>
  <div data-expense-payment-target="creditCardField" style="display: none;">
    <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;">Credit Card</label>
    <%= f.select :credit_card_id,
        [["— Select Card —", ""]] + credit_cards.map { |c| [c.name, c.id] },
        { include_blank: false },
        class: "w-full px-3 py-2.5 rounded-lg border text-sm outline-none focus:ring-2 transition-all",
        style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;" %>
  </div>

  <%# Installments %>
  <% if expense.new_record? %>
    <%# New record: show editable installments count %>
    <div data-expense-payment-target="installmentsField" style="display: none;">
      <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;">Installments</label>
      <div class="flex items-center gap-3">
        <%= f.number_field :total_installments, min: 1, max: 60, value: 1,
            class: "w-24 px-3 py-2.5 rounded-lg border text-sm outline-none focus:ring-2 transition-all",
            style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;",
            data: { expense_payment_target: "installments", action: "input->expense-payment#installmentsChanged" } %>
        <span class="text-xs" style="color: #8892A4;">
          Per installment: <span data-expense-payment-target="perInstallmentDisplay" class="font-medium" style="color: #E2E8F0;">R$ 0,00</span>
        </span>
      </div>
    </div>
  <% elsif expense.installment? %>
    <%# Editing an existing installment: show read-only info and preserve values %>
    <%= f.hidden_field :total_installments %>
    <%= f.hidden_field :installment_number %>
    <%= f.hidden_field :installment_group_id %>
    <div class="px-3 py-2.5 rounded-lg border text-sm" style="background-color: rgba(245,158,11,0.08); border-color: rgba(245,158,11,0.3);">
      <span style="color: #F59E0B;">Installment <%= expense.installment_label %></span>
      <span class="ml-2" style="color: #8892A4;">— only this installment will be updated</span>
    </div>
  <% end %>

  <%# Recurring toggle %>
  <div class="flex items-center gap-3" data-expense-payment-target="recurringField">
    <%= f.check_box :recurring, class: "w-4 h-4 rounded", style: "accent-color: #6C63FF;",
        data: { expense_payment_target: "recurring", action: "change->expense-payment#recurringChanged" } %>
    <label class="text-sm" style="color: #8892A4;">Recurring expense</label>
  </div>

  <%# Submit %>
  <div class="flex gap-3 pt-2">
    <%= f.submit expense.new_record? ? "Add Expense" : "Update Expense",
        class: "flex-1 py-2.5 rounded-lg text-sm font-semibold cursor-pointer transition-colors hover:opacity-90",
        style: "background-color: #6C63FF; color: white;" %>
    <% if defined?(cancel_path) && cancel_path %>
      <%= link_to "Cancel", cancel_path, class: "px-4 py-2.5 rounded-lg text-sm font-medium transition-colors hover:bg-white/5", style: "color: #8892A4;" %>
    <% end %>
  </div>
<% end %>

<style>
  input[type="radio"].sr-only:checked + div {
    border-color: #6C63FF !important;
    background-color: rgba(108,99,255,0.1);
  }
  input:focus, select:focus {
    ring-color: #6C63FF;
    border-color: #6C63FF !important;
  }
</style>
