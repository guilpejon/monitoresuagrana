<% if params[:quick].present? %>
  <%# Quick-add modal content (returned as HTML fragment) %>
  <div class="space-y-1">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-base font-semibold" style="color: #E2E8F0;">Quick Add Expense</h2>
      <button type="button" onclick="document.getElementById('modal').classList.add('hidden'); document.getElementById('modal-content').innerHTML='';" class="p-1.5 rounded-lg hover:bg-white/5 transition-colors" style="color: #8892A4;">
        <%= svg_icon "x", css_class: "w-4 h-4" %>
      </button>
    </div>
    <%= render "form", expense: @expense, categories: @categories, credit_cards: @credit_cards, cancel_path: nil %>
  </div>
<% else %>
  <%# Full page new expense %>
  <div class="max-w-lg mx-auto">
    <div class="flex items-center gap-3 mb-6">
      <%= link_to expenses_path, class: "p-2 rounded-lg hover:bg-white/5 transition-colors", style: "color: #8892A4;" do %>
        <%= svg_icon "chevron-left", css_class: "w-5 h-5" %>
      <% end %>
      <h1 class="text-xl font-bold" style="color: #E2E8F0;">New Expense</h1>
    </div>
    <div class="rounded-xl border p-6" style="background-color: #1E2130; border-color: #2A2F45;">
      <%= render "form", expense: @expense, categories: @categories, credit_cards: @credit_cards, cancel_path: expenses_path %>
    </div>
  </div>
<% end %>
