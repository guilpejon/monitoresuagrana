<%= form_with model: category, class: "space-y-4" do |f| %>
  <% if category.errors.any? %>
    <div class="px-4 py-3 rounded-lg border text-sm" style="background-color: rgba(255,107,107,0.1); border-color: #FF6B6B; color: #FF6B6B;">
      <% category.errors.full_messages.each do |msg| %><p><%= msg %></p><% end %>
    </div>
  <% end %>

  <div>
    <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;"><%= t("categories.form.name") %></label>
    <%= f.text_field :name, class: "w-full px-3 py-2.5 rounded-lg border text-sm outline-none transition-all", style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;", placeholder: t("categories.form.name_placeholder"), autofocus: true, maxlength: 20 %>
  </div>

  <div>
    <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;"><%= t("categories.form.color") %></label>
    <div class="flex flex-wrap gap-2">
      <% ColorPalette::COLORS.each do |color| %>
        <label class="cursor-pointer">
          <%= f.radio_button :color, color, class: "sr-only peer" %>
          <span class="block w-8 h-8 rounded-lg peer-checked:ring-2 peer-checked:ring-offset-2 peer-checked:ring-offset-[#1E2130] peer-checked:ring-white transition-all hover:opacity-80"
                style="background-color: <%= color %>;"></span>
        </label>
      <% end %>
    </div>
  </div>

  <div>
    <label class="block text-xs font-medium mb-2" style="color: #8892A4;"><%= t("categories.form.icon") %> <span style="color: #FF6B6B;">*</span></label>
    <div class="grid grid-cols-6 gap-2">
      <% %w[home utensils car heart-pulse gamepad-2 shopping-cart book-open zap plane layers wallet trending-up credit-card bar-chart-2 tag calendar clock repeat music search paw-print dumbbell coffee gift phone umbrella scissors shirt pill baby].each do |icon_name| %>
        <label class="cursor-pointer">
          <%= f.radio_button :icon, icon_name, class: "sr-only peer", id: "icon_#{icon_name}" %>
          <div class="w-10 h-10 rounded-lg flex items-center justify-center border transition-all hover:border-purple-500 peer-checked:border-purple-500 peer-checked:bg-purple-500/10"
               style="border-color: #2A2F45;">
            <%= svg_icon icon_name, css_class: icon_css_class(icon_name, default: "w-4 h-4"), stroke: "#8892A4" %>
          </div>
        </label>
      <% end %>
    </div>
    <% if category.errors[:icon].any? %>
      <p class="mt-1.5 text-xs" style="color: #FF6B6B;"><%= category.errors[:icon].first %></p>
    <% end %>
  </div>

  <div class="flex items-center gap-3">
    <%= check_box_tag :set_as_default, "1", current_user.default_category_id == category.id,
        class: "w-4 h-4 rounded", style: "accent-color: #6C63FF;" %>
    <label class="text-sm" style="color: #8892A4;"><%= t("categories.form.set_as_default") %></label>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit category.new_record? ? t("categories.form.add") : t("categories.form.update"), class: "flex-1 py-2.5 rounded-lg text-sm font-semibold cursor-pointer transition-colors hover:opacity-90", style: "background-color: #6C63FF; color: white;" %>
    <%= link_to t("categories.form.cancel"), categories_path, class: "px-4 py-2.5 rounded-lg text-sm font-medium transition-colors hover:bg-white/5", style: "color: #8892A4;" %>
  </div>
<% end %>

<style>
  input[type="radio"].sr-only:checked + div {
    border-color: #6C63FF !important;
    background-color: rgba(108,99,255,0.1);
  }
</style>
